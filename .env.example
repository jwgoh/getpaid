# ===========================================
# Required
# ===========================================

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/getpaid?schema=public"

# NextAuth — REQUIRED. Generate with: openssl rand -base64 32
# Must be at least 32 chars. Never commit. JWTs are signed with this.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# App
APP_URL="http://localhost:3000"

# Edition — controls feature availability
# "community" (default): open registration, self-hosted features
# "pro": closed registration (invite-only), premium features
# NEXT_PUBLIC_GETPAID_EDITION="community"

# ===========================================
# Docker Compose only (required when running via docker-compose.yml)
# ===========================================

# Postgres password used by the bundled db service. Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=""
# POSTGRES_USER="getpaid"
# POSTGRES_DB="getpaid"

# ===========================================
# Optional
# ===========================================

# Email (Resend) — required for sending invoices via email
# Get your API key at https://resend.com
# RESEND_API_KEY="re_your_resend_api_key"
# EMAIL_FROM="invoices@yourdomain.com"

# Admin email — required for waitlist-admin routes (gates `pro` edition admin endpoints)
# ADMIN_EMAIL="your-admin-email@example.com"

# Encryption key — required for time-tracking integrations (Toggl OAuth token AES-GCM)
# Must be at least 32 chars. Generate via: openssl rand -base64 32
# ENCRYPTION_KEY="change-me-please-32-bytes-base64"

# NextAuth v5 — required when running behind a reverse proxy (Docker, Vercel preview, etc.)
# Tells NextAuth to trust X-Forwarded-* headers. Set to "true" in such setups.
# AUTH_TRUST_HOST="true"
