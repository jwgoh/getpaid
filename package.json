{
  "name": "getpaid",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "build:analyze": "ANALYZE=true pnpm build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"{src,prisma,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{ts,mjs,json,md}\"",
    "format:check": "prettier --check \"{src,prisma,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\" \"*.{ts,mjs,json,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push:dev-only": "prisma db push",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "outbox:run": "tsx scripts/process-outbox.ts",
    "prune:expired": "tsx scripts/prune-expired.ts",
    "postinstall": "prisma generate",
    "prepare": "lefthook install",
    "db:seed": "prisma db seed"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@hookform/resolvers": "^5.2.2",
    "@mui/icons-material": "^7.3.7",
    "@mui/material": "^7.3.7",
    "@mui/x-date-pickers": "^8.27.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-virtual": "^3.13.18",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.19",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "nanoid": "^5.1.6",
    "next": "16.2.6",
    "next-auth": "5.0.0-beta.30",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@faker-js/faker": "^10.4.0",
    "@next/bundle-analyzer": "^16.2.6",
    "@types/node": "^22.19.19",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.7",
    "dotenv": "^16.5.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "lefthook": "^2.1.0",
    "prettier": "^3.8.1",
    "prisma": "^7.8.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "@prisma/client": "7"
      }
    },
    "overrides": {
      "minimatch@<3.1.4": "^3.1.4",
      "postcss@<8.5.10": "^8.5.10",
      "uuid@<11.1.1": "^11.1.1",
      "nodemailer@<8.0.5": "^8.0.5",
      "mailparser@<3.9.3": "^3.9.3",
      "@hono/node-server@<1.19.13": "^1.19.13"
    }
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "engines": {
    "node": ">=22 <23",
    "pnpm": ">=10"
  }
}
