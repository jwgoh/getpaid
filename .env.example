# ===========================================
# Required
# ===========================================

# Database (PostgreSQL)
# On Vercel / serverless: prefer a pooled connection string (Neon `-pooler` host,
# Supabase port 6543, or pgBouncer in transaction-pool mode) so each function
# instance reuses a single upstream connection. The Prisma adapter is pinned to
# max=1 connection per instance in src/server/db/index.ts to keep cold starts
# from exhausting Postgres `max_connections` (default 100).
DATABASE_URL="postgresql://user:password@localhost:5432/getpaid?schema=public"

# NextAuth — REQUIRED. Generate with: openssl rand -base64 32
# Must be at least 32 chars. Never commit. JWTs are signed with this.
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# App
APP_URL="http://localhost:3000"

# Edition — controls feature availability
# "community" (default): open registration, self-hosted features
# "pro": closed registration (invite-only), premium features
# NEXT_PUBLIC_GETPAID_EDITION="community"

# ===========================================
# Docker Compose only (required when running via docker-compose.yml)
# ===========================================

# Postgres password used by the bundled db service. Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=""
# POSTGRES_USER="getpaid"
# POSTGRES_DB="getpaid"

# ===========================================
# Optional
# ===========================================

# Email (Resend) — required for sending invoices via email
# Get your API key at https://resend.com
# RESEND_API_KEY="re_your_resend_api_key"
# EMAIL_FROM="invoices@yourdomain.com"

# Admin email — required for waitlist-admin routes (gates `pro` edition admin endpoints)
# ADMIN_EMAIL="your-admin-email@example.com"

# Encryption key — required for time-tracking integrations (Toggl OAuth token AES-GCM)
# Must base64-decode to exactly 32 bytes. Generate via: openssl rand -base64 32
# ENCRYPTION_KEY="your-base64-encoded-32-byte-key-here"

# NextAuth v5 — required when running behind a reverse proxy (Docker, Vercel preview, etc.)
# Tells NextAuth to trust X-Forwarded-* headers. Set to "true" in such setups.
# AUTH_TRUST_HOST="true"

# Trusted proxy hops — how many proxies sit between the public internet and the app.
# Used by the rate limiter to pick the real client IP from X-Forwarded-For.
# Each trusted proxy appends the connecting peer's IP to X-Forwarded-For, so the
# real client IP is at position (length - TRUSTED_PROXY_HOPS).
# Set to:
#   1  - default; one proxy in front (Vercel, single nginx/Caddy/Traefik).
#   2+ - multiple proxies (e.g. Cloudflare → nginx → app).
#   0  - no proxy; ALL proxy headers (X-Forwarded-For AND X-Real-IP) are ignored
#        and the rate limiter keys on "unknown" — effectively a single shared bucket.
# TRUSTED_PROXY_HOPS="1"
